<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EFMDS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            :root {
                --vezeeta-primary: #00b8a9;
                --vezeeta-primary-dark: #009688;
                --vezeeta-surface: #ffffff;
                --vezeeta-bg: #f4fbfa;
                --vezeeta-text: #103b39;
            }

            body {
                background:
                    radial-gradient(circle at top right, rgba(0, 184, 169, 0.12), transparent 28%),
                    linear-gradient(180deg, var(--vezeeta-bg) 0%, #ffffff 100%);
                min-height: 100vh;
                color: var(--vezeeta-text);
            }

            .page-shell {
                padding: 2rem 0 3rem;
            }

            .surface-card {
                border: 0;
                border-radius: 1.5rem;
                background: var(--vezeeta-surface);
                box-shadow: 0 1rem 2.5rem rgba(16, 59, 57, 0.08);
            }

            .btn-primary {
                --bs-btn-bg: var(--vezeeta-primary);
                --bs-btn-border-color: var(--vezeeta-primary);
                --bs-btn-hover-bg: var(--vezeeta-primary-dark);
                --bs-btn-hover-border-color: var(--vezeeta-primary-dark);
                --bs-btn-active-bg: var(--vezeeta-primary-dark);
                --bs-btn-active-border-color: var(--vezeeta-primary-dark);
            }

            .text-vezeeta {
                color: var(--vezeeta-primary-dark);
            }

            .bg-vezeeta-soft {
                background: linear-gradient(135deg, rgba(0, 184, 169, 0.12), rgba(16, 59, 57, 0.05));
            }
    </style>
</head>

<body>
    @await Html.PartialAsync("_Navbar")

    <main class="page-shell">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>