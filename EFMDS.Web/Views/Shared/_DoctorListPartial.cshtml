@model IEnumerable<EFMDS.Web.ViewModels.DoctorViewModel>

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5 rounded-4 shadow-sm border-0">
        <h4 class="fw-bold mb-3">لا توجد نتائج</h4>
        <p class="mb-0">لم نتمكن من العثور على أطباء يطابقون خيارات التصفية.</p>
    </div>
}
else
{
    foreach(var doctor in Model)
    {
        <partial name="_DoctorCard" model="doctor" />
    }
}
