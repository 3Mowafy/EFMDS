@model List<EFMDS.Web.Models.Governorate>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <span
        class="badge rounded-pill text-bg-success-subtle text-vezeeta border border-success-subtle px-3 py-2 mb-2">Governorates</span>
        <h1 class="h3 fw-bold mb-1">Governorates</h1>
        <p class="text-body-secondary mb-0">Manage the governorates used by the rest of the site.</p>
    </div>
    <a class="btn btn-primary btn-lg" asp-controller="Governorates" asp-action="Create">Add Governorate</a>
</div>

<div class="card surface-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background: rgba(0, 184, 169, 0.08);">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Name Ar</th>
                        <th>Name En</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var governorate in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-vezeeta">@governorate.Id</td>
                                <td>@governorate.NameAr</td>
                                <td>@governorate.NameEn</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Governorate actions">
                                        <a class="btn btn-outline-secondary" asp-controller="Governorates" asp-action="Details"
                                           asp-route-id="@governorate.Id">Details</a>
                                        <a class="btn btn-outline-primary" asp-controller="Governorates" asp-action="Edit"
                                           asp-route-id="@governorate.Id">Edit</a>
                                        <a class="btn btn-outline-danger" asp-controller="Governorates" asp-action="Delete"
                                           asp-route-id="@governorate.Id">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-body-secondary">No governorates found yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>