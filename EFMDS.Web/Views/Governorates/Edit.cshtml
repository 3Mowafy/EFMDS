@model EFMDS.Web.Models.Governorate

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card surface-card">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <span
                        class="badge rounded-pill text-bg-success-subtle text-vezeeta border border-success-subtle px-3 py-2 mb-2">Update
                        governorate</span>
                        <h1 class="h3 fw-bold mb-2">Edit Governorate</h1>
                        <p class="text-body-secondary mb-0">Update the governorate data and save the changes.</p>
                    </div>

                    <form method="post" action="/governorates/edit/@Model.Id" class="row g-3 needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@Model.Id" />
                        <div class="col-md-6">
                            <label for="NameAr" class="form-label">Name Ar</label>
                            <input type="text" class="form-control" id="NameAr" name="NameAr" value="@Model.NameAr" required
                                   minlength="2" maxlength="100" />
                            <div class="invalid-feedback">Name Ar is required and must be at least 2 characters.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="NameEn" class="form-label">Name En</label>
                            <input type="text" class="form-control" id="NameEn" name="NameEn" value="@Model.NameEn" required
                                   minlength="2" maxlength="100" />
                            <div class="invalid-feedback">Name En is required and must be at least 2 characters.</div>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Update</button>
                            <a href="/governorates" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const form = document.querySelector('.needs-validation');
            if (!form) return;

            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }

                form.classList.add('was-validated');
            }, false);
        })();
    </script>