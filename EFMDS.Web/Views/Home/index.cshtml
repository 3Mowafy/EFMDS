<div class="row justify-content-center g-4">
    <div class="col-12 col-xl-11">
        <div class="card surface-card overflow-hidden">
            <div class="row g-0">
                <div class="col-lg-7 p-4 p-md-5">
                    <span
                        class="badge rounded-pill text-bg-success-subtle text-vezeeta border border-success-subtle mb-3 px-3 py-2">Healthcare
                        management</span>
                        <h1 class="display-5 fw-bold mb-3">إدارة الواجهة الأساسية للمشروع من مكان واحد</h1>
                        <p class="lead text-body-secondary mb-4">
                            من هنا تقدر تدخل على الأقسام الجديدة وتختبر صفحات الـ views الخاصة بالـ specialties والـ
                            governorates والـ districts بسرعة.
                        </p>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary btn-lg px-4" asp-controller="Specialties"
                               asp-action="Index">Specialties</a>
                            <a class="btn btn-outline-success btn-lg px-4" asp-controller="Governorates"
                               asp-action="Index">Governorates</a>
                            <a class="btn btn-outline-primary btn-lg px-4" asp-controller="Districts"
                               asp-action="Index">Districts</a>
                        </div>
                        <div class="mt-3 d-flex flex-wrap gap-2">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="badge rounded-pill text-bg-light border px-3 py-2">Logged in as
                                    @User.Identity.Name</span>
                                    <form asp-controller="Account" asp-action="Logout" method="post" asp-antiforgery="false"
                                          class="d-inline m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                                    </form>
                                }
                            else
                                {
                                    <a class="btn btn-outline-dark btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                                    <a class="btn btn-outline-dark btn-sm" asp-controller="Account"
                                       asp-action="Register">Register</a>
                                }
                            </div>
                            <div class="mt-4 d-flex flex-wrap gap-2">
                                <span class="badge rounded-pill text-bg-light border px-3 py-2">RTL ready</span>
                                <span class="badge rounded-pill text-bg-light border px-3 py-2">Bootstrap views</span>
                                <span class="badge rounded-pill text-bg-light border px-3 py-2">CRUD pages</span>
                            </div>
                        </div>
                        <div class="col-lg-5 bg-vezeeta-soft p-4 p-md-5 d-flex align-items-center">
                            <div class="w-100">
                                <div class="card border-0 shadow-sm rounded-4 mb-3">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-4 bg-success-subtle text-vezeeta d-flex align-items-center justify-content-center fw-bold"
                                                 style="width: 3rem; height: 3rem;">1</div>
                                            <div>
                                                <div class="fw-semibold">Specialties</div>
                                                <div class="text-body-secondary small">قائمة، إضافة، تعديل، تفاصيل، وحذف.</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card border-0 shadow-sm rounded-4 mb-3">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-4 bg-success-subtle text-vezeeta d-flex align-items-center justify-content-center fw-bold"
                                                 style="width: 3rem; height: 3rem;">2</div>
                                            <div>
                                                <div class="fw-semibold">Governorates</div>
                                                <div class="text-body-secondary small">صفحات جاهزة لإدارة المحافظات.</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-4 bg-success-subtle text-vezeeta d-flex align-items-center justify-content-center fw-bold"
                                                 style="width: 3rem; height: 3rem;">3</div>
                                            <div>
                                                <div class="fw-semibold">Districts</div>
                                                <div class="text-body-secondary small">إضافة وربط الحي بالمحافظة من خلال القائمة
                                                    المنسدلة.</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-11">
                    <div class="card surface-card border-success-subtle">
                        <div class="card-body p-4 p-md-5">
                            <div class="row align-items-center g-4">
                                <div class="col-lg-7">
                                    <span
                                        class="badge rounded-pill text-bg-success-subtle text-vezeeta border border-success-subtle px-3 py-2 mb-3">Account
                                        access</span>
                                        <h2 class="h3 fw-bold mb-2">صفحات تسجيل الدخول جاهزة</h2>
                                        <p class="text-body-secondary mb-0">
                                            لو عايز تفتح الصفحات الخاصة بالحساب مباشرة، استخدم الأزرار دي من هنا أو من النافبار.
                                        </p>
                                    </div>
                                    <div class="col-lg-5">
                                        <div class="d-grid gap-2">
                                            @if (User.Identity?.IsAuthenticated == true)
                                            {
                                                <div class="alert alert-success mb-0">أنت داخل الآن باسم @User.Identity.Name</div>
                                                <form asp-controller="Account" asp-action="Logout" method="post" asp-antiforgery="false"
                                                      class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger w-100">Logout</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Login">Login</a>
                                                <a class="btn btn-outline-success btn-lg" asp-controller="Account"
                                                   asp-action="Register">Register</a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xl-11">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="card surface-card h-100">
                                    <div class="card-body p-4">
                                        <div class="text-body-secondary small mb-2">Specialties</div>
                                        <h2 class="h4 fw-bold mb-2">جاهزة للإدارة</h2>
                                        <p class="text-body-secondary mb-3">اعرض الأقسام الطبية، أضف جديد، أو عدّل بيانات موجودة بسرعة.
                                        </p>
                                        <div class="d-grid gap-2">
                                            <a class="btn btn-outline-primary" asp-controller="Specialties" asp-action="Index">Open
                                                list</a>
                                                <a class="btn btn-outline-success" asp-controller="Specialties" asp-action="Create">Add
                                                    new</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card surface-card h-100">
                                            <div class="card-body p-4">
                                                <div class="text-body-secondary small mb-2">Governorates</div>
                                                <h2 class="h4 fw-bold mb-2">المحافظات</h2>
                                                <p class="text-body-secondary mb-3">إدارة المحافظات المستخدمة في ربط الـ districts وتنسيق
                                                    البيانات.</p>
                                                    <div class="d-grid gap-2">
                                                        <a class="btn btn-outline-primary" asp-controller="Governorates" asp-action="Index">Open
                                                            list</a>
                                                            <a class="btn btn-outline-success" asp-controller="Governorates" asp-action="Create">Add
                                                                new</a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="card surface-card h-100">
                                                        <div class="card-body p-4">
                                                            <div class="text-body-secondary small mb-2">Districts</div>
                                                            <h2 class="h4 fw-bold mb-2">الأحياء</h2>
                                                            <p class="text-body-secondary mb-3">ربط كل district بمحافظة من خلال الفورم الجاهز والـ dropdown.
                                                            </p>
                                                            <div class="d-grid gap-2">
                                                                <a class="btn btn-outline-primary" asp-controller="Districts" asp-action="Index">Open
                                                                    list</a>
                                                                    <a class="btn btn-outline-success" asp-controller="Districts" asp-action="Create">Add
                                                                        new</a>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>