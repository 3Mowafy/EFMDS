@model EFMDS.Web.ViewModels.DoctorViewModel
@{
    ViewData["Title"] = "تفاصيل الطبيب - " + Model.Name;
}

<div class="row justify-content-center g-4 my-4">
    <div class="col-12 col-xl-11">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-primary">الرئيسية</a></li>
                <li class="breadcrumb-item"><a href="/Listing" class="text-decoration-none text-primary">الأطباء</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>

        <div class="row g-4">
            <!-- Doctor Main Info & Details -->
            <div class="col-lg-8">
                <!-- Header Card -->
                <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex flex-column flex-md-row gap-4 align-items-center align-items-md-start">
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded-circle shadow-sm border border-3 border-white" width="140" height="140" style="object-fit: cover;">
                            <div class="text-center text-md-end flex-grow-1">
                                <h1 class="fw-bold text-primary mb-2 d-flex align-items-center justify-content-center justify-content-md-start gap-2">
                                    @Model.Name
                                    <span class="badge bg-success bg-opacity-10 text-success fs-6 rounded-pill px-3 py-1 border border-success-subtle fw-normal">
                                        <i class="bi bi-check-circle-fill me-1"></i> موثق
                                    </span>
                                </h1>
                                <p class="fs-5 text-secondary mb-3">
                                    <span class="badge bg-light text-dark border me-2 px-3 py-2 rounded-pill">@Model.Title</span> 
                                    @Model.Specialty
                                </p>
                                
                                <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-4 text-muted mt-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="stars text-warning fs-5">
                                            @for(int i = 1; i <= 5; i++)
                                            {
                                                if(i <= Math.Round(Model.Rating)) {
                                                    <span>★</span>
                                                } else {
                                                    <span class="text-muted opacity-25">★</span>
                                                }
                                            }
                                        </div>
                                        <span class="fw-bold text-dark fs-5">@Model.Rating</span>
                                        <span class="small">من @Model.ReviewsCount زائر</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2 fs-5">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-eye text-primary" viewBox="0 0 16 16">
                                          <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                                          <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                                        </svg>
                                        <span>مشاهدات: <strong class="text-dark">@((Model.ReviewsCount * 3) + 120)</strong></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info Cards -->
                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4 p-md-5">
                        <h4 class="fw-bold mb-4 text-primary border-bottom pb-3">نبذة عن الطبيب</h4>
                        <p class="fs-5 text-secondary lh-lg mb-0">@Model.About</p>
                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-6 border-md-end">
                                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2 text-primary">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-mortarboard-fill" viewBox="0 0 16 16">
                                      <path d="M8.211 2.047a.5.5 0 0 0-.422 0l-7.5 3.5a.5.5 0 0 0 .025.917l7.5 3a.5.5 0 0 0 .372 0L14 7.14V13a1 1 0 0 0-1 1v2h3v-2a1 1 0 0 0-1-1V6.739l.686-.275a.5.5 0 0 0 .025-.917l-7.5-3.5Z"/>
                                      <path d="M4.176 9.032a.5.5 0 0 0-.656.327l-.5 1.7a.5.5 0 0 0 .294.605l4.5 1.8a.5.5 0 0 0 .372 0l4.5-1.8a.5.5 0 0 0 .294-.605l-.5-1.7a.5.5 0 0 0-.656-.327L8 10.466 4.176 9.032Z"/>
                                    </svg>
                                    التعليم الأكاديمي
                                </h5>
                                <p class="text-secondary fs-5 mb-0">@Model.Education</p>
                            </div>
                            <div class="col-md-6 pt-3 pt-md-0">
                                <h5 class="fw-bold mb-3 d-flex align-items-center gap-2 text-primary">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-award-fill" viewBox="0 0 16 16">
                                      <path d="m8 0 1.669.864 1.858.282.842 1.68 1.337 1.32L13.4 6l.306 1.854-1.337 1.32-.842 1.68-1.858.282L8 12l-1.669-.864-1.858-.282-.842-1.68-1.337-1.32L2.6 6l-.306-1.854 1.337-1.32.842-1.68L6.331.864 8 0z"/>
                                      <path d="M4 11.794V16l4-1 4 1v-4.206l-2.018.306L8 13.126 6.018 12.1 4 11.794z"/>
                                    </svg>
                                    الخبرات
                                </h5>
                                <p class="text-secondary fs-5 mb-0">@Model.Experience</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Booking Widget Sidebar -->
            <div class="col-lg-4">
                <div class="card shadow border-0 rounded-4 sticky-lg-top" style="top: 2rem;">
                    <div class="card-header bg-primary text-white p-4 rounded-top-4 border-0">
                        <h4 class="mb-0 fw-bold text-center">معلومات الحجز</h4>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex flex-column gap-4">
                            <div class="d-flex align-items-start gap-3">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-geo-alt-fill" viewBox="0 0 16 16">
                                        <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
                                    </svg>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">العيادة</h6>
                                    <p class="text-secondary mb-0">@Model.Location</p>
                                </div>
                            </div>
                            
                            <div class="d-flex align-items-start gap-3">
                                <div class="bg-success bg-opacity-10 text-success rounded-circle p-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-cash-stack" viewBox="0 0 16 16">
                                        <path d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1H1zm7 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
                                        <path d="M0 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V5zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V7a2 2 0 0 1-2-2H3z"/>
                                    </svg>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">سعر الكشف</h6>
                                    <p class="text-secondary mb-0 fw-bold fs-5">@Model.Price ج.م</p>
                                </div>
                            </div>

                            <div class="d-flex align-items-start gap-3">
                                <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-clock-history" viewBox="0 0 16 16">
                                        <path d="M8.515 1.019A7 7 0 0 0 8 1V0a8 8 0 0 1 .589.022l-.074.997zm2.004.45a7.003 7.003 0 0 0-.985-.299l.219-.976c.383.086.76.2 1.126.342l-.36.933zm1.37.71a7.01 7.01 0 0 0-.439-.27l.493-.87a8.025 8.025 0 0 1 .979.654l-.615.789a6.996 6.996 0 0 0-.418-.302zm1.834 1.79a6.99 6.99 0 0 0-.653-.796l.724-.69c.27.285.52.59.747.91l-.818.576zm.744 1.352a7.08 7.08 0 0 0-.214-.468l.893-.45a7.976 7.976 0 0 1 .45 1.088l-.95.313a7.023 7.023 0 0 0-.179-.483zm.53 2.507a6.991 6.991 0 0 0-.1-1.025l.985-.17c.067.386.106.778.116 1.17l-1 .025zm-.131 1.538c.033-.17.06-.339.081-.51l.993.123a7.957 7.957 0 0 1-.23 1.155l-.964-.267c.046-.165.086-.332.12-.501zm-.952 2.379c.184-.29.346-.594.486-.908l.914.405c-.16.36-.345.706-.555 1.038l-.845-.535zm-.964 1.205c.122-.122.239-.248.35-.378l.758.653a8.073 8.073 0 0 1-.401.432l-.707-.707z"/>
                                        <path d="M8 1a7 7 0 1 0 4.95 11.95l.707.707A8.001 8.001 0 1 1 8 0v1z"/>
                                        <path d="M7.5 3a.5.5 0 0 1 .5.5v5.21l3.248 1.856a.5.5 0 0 1-.496.868l-3.5-2A.5.5 0 0 1 7 9V3.5a.5.5 0 0 1 .5-.5z"/>
                                    </svg>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">مدة الانتظار</h6>
                                    <p class="text-secondary mb-0">@Model.WaitTime</p>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <h6 class="fw-bold text-center mb-3 text-primary">المواعيد المتاحة</h6>
                        @if(Model.AvailableAppointments != null && Model.AvailableAppointments.Any())
                        {
                            <div class="row g-2 mb-4">
                                @foreach(var apt in Model.AvailableAppointments)
                                {
                                    <div class="col-6">
                                        <button class="btn btn-outline-primary w-100 rounded-3 py-2 time-slot-btn fw-semibold shadow-sm">
                                            @apt
                                        </button>
                                    </div>
                                }
                            </div>
                            
                            <button class="btn btn-primary w-100 btn-lg rounded-pill fw-bold shadow hover-lift py-3 fs-5">
                                تأكيد الحجز <i class="bi bi-calendar-check ms-2"></i>
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-secondary text-center rounded-3">لا توجد مواعيد متاحة قريباً</div>
                        }
                        
                        <p class="text-center text-muted small mt-3 mb-0">الحجز مجاني والدفع في العيادة</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
